{
  "name": "teamup-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run clean && prisma generate && tsc && npm run copy-files && node scripts/resolve-failed-migrations.js && prisma migrate deploy",
    "postinstall": "prisma generate",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "copy-files": "copyfiles -u 1 src/**/*.pug src/**/*.json dist/",
    "format": "prettier --write src/**/*.ts",
    "db:seed": "npx tsx prisma/seed.ts --reset",
    "db:reset": "npx tsx prisma/seed.ts --reset",
    "test:flows": "npx tsx scripts/test-flows.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.6",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.20.0",
    "@types/pug": "^2.0.10",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "pug": "^3.0.3",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.2.1",
    "typescript": "^5.9.2",
    "xss-shield": "^1.0.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  }
}
