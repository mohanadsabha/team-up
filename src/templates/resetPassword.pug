doctype html
html
  head
    style.
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333333;
      }
      .header {
        background-color: #0f766e;
        color: #ffffff;
        padding: 20px;
        text-align: center;
        border-radius: 6px 6px 0 0;
      }
      .content {
        padding: 20px;
        border: 1px solid #dddddd;
        border-top: 0;
        border-radius: 0 0 6px 6px;
      }
      .button {
        display: inline-block;
        margin-top: 16px;
        padding: 10px 16px;
        text-decoration: none;
        border-radius: 4px;
        color: #ffffff;
        background-color: #0f766e;
      }
      .small {
        margin-top: 20px;
        font-size: 12px;
        color: #666666;
      }
  body
    .email-container
      .header
        h2= subject
      .content
        p Hi #{name},
        p We received a request to reset your password.
        p Click the button below to set a new password:
        a.button(href=resetUrl, target="_blank", rel="noopener noreferrer") Reset Password
        p.small
          | If you did not request this, you can ignore this email.
          br
          | This link expires in 15 minutes.
